# Local test credentials for test-print.mjs. Copy this file to `.env` and fill in
# the real values (from the password manager). `.env` is gitignored — never commit it.
# These mirror the Apps Script Script Properties of the same name.

PI_URL=https://<your-subdomain>.ngrok.app
NGROK_USER=
NGROK_PASS=

# Optional — only for `node test-print.mjs art:live` (live Fable art test).
ANTHROPIC_KEY=
# Optional weather context for art:live (mirror the Script Properties).
GEMINI_KEY=
LAT=
LON=
